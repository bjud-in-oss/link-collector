                        </div>
                        <div className="col-span-2 text-center cursor-pointer hover:bg-fuchsia-500/10 rounded" onClick={() => onExplain('P_SAF')}>
                            <div className="text-[8px] text-fuchsia-300">MARGIN (2σ)</div>
