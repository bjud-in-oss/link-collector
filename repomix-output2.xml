                        </div>
                    </div>
                </>
            )}

            {/* LOGIC & SHIELD */}
            <Header text="Logic & Shield (Protection)" color="text-emerald-500/70" id="logic" isOpen={isOpen('logic')} onToggle={toggleGroup} />
            
            {isOpen('logic') && (
                <>
